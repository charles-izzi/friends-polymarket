rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is a member of the given market
    function isMember(marketId) {
      return exists(/databases/$(database)/documents/markets/$(marketId)/members/$(request.auth.uid));
    }

    // Markets: members can read their market doc.
    // Unauthenticated writes blocked; all writes via Cloud Functions (admin SDK).
    match /markets/{marketId} {
      allow read: if request.auth != null && isMember(marketId);
      allow write: if false;

      // Members: market members can list all members.
      match /members/{userId} {
        allow read: if request.auth != null && isMember(marketId);
        allow write: if false;
      }

      // Bets: market members can read all bets.
      match /bets/{betId} {
        allow read: if request.auth != null && isMember(marketId);
        allow write: if false;

        match /positions/{posUserId} {
          allow read: if request.auth != null && isMember(marketId);
          allow write: if false;
        }

        match /trades/{tradeId} {
          allow read: if request.auth != null && isMember(marketId);
          allow write: if false;
        }

        match /comments/{commentId} {
          allow read: if request.auth != null && isMember(marketId);
          allow write: if false;
        }
      }

      // Stats: market members can read all stats.
      match /stats/{userId} {
        allow read: if request.auth != null && isMember(marketId);
        allow write: if false;
      }
    }

    // CollectionGroup rule for 'members' — allows the collectionGroup query
    // used to find which markets a user belongs to. Only lets a user read
    // their own member documents across all markets.
    match /{path=**}/members/{memberId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Users collection — stores FCM tokens per user (top-level, not per-market).
    // Each user can only read/write their own document and subcollections.
    match /users/{userId} {
      allow read, write: if false; // user doc itself is admin-only

      match /fcmTokens/{tokenId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // managed by cloud functions
      }
    }
  }
}
